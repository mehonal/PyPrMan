SECRET_KEY=generate-a-strong-random-key-here
SECURITY_PASSWORD_SALT=generate-a-different-random-salt-here

# Production database (default: SQLite in instance/prod.db)
# DATABASE_URL=sqlite:///instance/prod.db

# Mail settings (required in production for email notifications)
# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=your-email@example.com
# MAIL_PASSWORD=your-email-password
# MAIL_DEFAULT_SENDER=noreply@example.com
